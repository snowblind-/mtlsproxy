#!/bin/bash

# Send output to log file and serial console
mkdir -p  /var/log/cloud /config/cloud 
LOG_FILE=/var/log/cloud/startup-script.log
[[ ! -f $LOG_FILE ]] && touch $LOG_FILE || { echo "Run Only Once. Exiting"; exit; }
npipe=/tmp/$$.tmp
trap "rm -f $npipe" EXIT
mknod $npipe p
tee <$npipe -a $LOG_FILE /dev/ttyS0 &
exec 1>&-
exec 1>$npipe
exec 2>&1

# save config
tmsh save sys config
# Add remaining runtime_parameters:
cat << 'EOF' >> /config/cloud/runtime-init-conf.yaml
pre_onboard_enabled:
  - name: provision_rest
    type: inline
    commands:
      - /usr/bin/setdb provision.extramb 1000
extension_packages:
  install_operations:
    - extensionType: do
      extensionUrl: 'file:///var/config/rest/downloads/f5-declarative-onboarding-1.46.0-7.noarch.rpm'
      extensionVersion: 1.46.0
    - extensionType: as3
      extensionUrl: 'file:///var/config/rest/downloads/v3.54.1/f5-appsvcs-3.54.0-7.noarch.rpm'
      extensionVersion: 3.54.0
    - extensionType: ts
      extensionUrl: 'file:///var/config/rest/downloads/f5-telemetry-1.37.0-1.noarch.rpm'
      extensionVersion: 1.37.0
    - extensionType: cf
      extensionUrl: 'file:///var/config/rest/downloads/f5-cloud-failover-2.1.3-3.noarch.rpm'
      extensionVersion: 2.1.3

extension_services:
  service_operations:
    - extensionType: do
      type: inline
      value:
        schemaVersion: 1.0.0
        class: Device
        label: >-
          Quickstart 1NIC BIG-IP declaration for Declarative Onboarding with BYOL
        async: true
        Common:
          class: Tenant
          My_DbVariables:
            class: DbVariables
            ui.advisory.enabled: true
            ui.advisory.color: blue
            ui.advisory.text: BIG-IP Quickstart
          My_Provisioning:
            class: Provision
            ltm: nominal
          My_License:
            class: License
            licenseType: regKey
            regKey: 'XXXXX-XXXX-XXXXX-XXXXX'

    - extensionType: do
      type: url
      value: https://raw.githubusercontent.com/snowblind-/onboard/refs/heads/main/do.json

    - extensionType: as3
      type: url
      value: https://raw.githubusercontent.com/snowblind-/onboard/refs/heads/main/as3.json

post_onboard_enabled: []
EOF

# # Download
#
# Install
#bash chmod 777 /var/config/rest/downloads/f5-bigip-runtime-init-2.0.3-1.gz.run
#bash /var/config/rest/downloads/f5-bigip-runtime-init.gz.run -- '--cloud aws'
bash /var/config/rest/downloads/f5-bigip-runtime-init-2.0.3-1.gz.run -- '--cloud aws --skip-toolchain-metadata-sync'
# Run
export F5_BIGIP_RUNTIME_INIT_LOG_LEVEL=silly
f5-bigip-runtime-init --config-file /config/cloud/runtime-init-conf.yaml
